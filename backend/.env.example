# Django config not needed - FastAPI reads these directly via pydantic-settings

# App
DEBUG=true

# SQLite file (relative to backend/)
DATABASE_URL=sqlite:///./incident_mgmt.db

# CORS - allow Next.js dev server
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# AI feature — Groq free tier: https://console.groq.com/keys
# Leave blank to use keyword-based heuristic fallback (app still works without this)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
